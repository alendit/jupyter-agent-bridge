{
  "name": "@jupyter-mcp/extension",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/extension/src/extension.js",
  "engines": {
    "vscode": "^1.99.0"
  },
  "activationEvents": [
    "onNotebook:jupyter-notebook",
    "onCommand:jupyterMcp.startBridge",
    "onCommand:jupyterMcp.stopBridge",
    "onCommand:jupyterMcp.showStatus",
    "onCommand:jupyterMcp.copyMcpDefinition"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jupyterMcp.startBridge",
        "title": "Jupyter MCP: Start Bridge"
      },
      {
        "command": "jupyterMcp.stopBridge",
        "title": "Jupyter MCP: Stop Bridge"
      },
      {
        "command": "jupyterMcp.showStatus",
        "title": "Jupyter MCP: Show Status"
      },
      {
        "command": "jupyterMcp.copyMcpDefinition",
        "title": "Jupyter MCP: Copy MCP Definition"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/extension/src/notebook/CellPatchService.test.js dist/extension/src/notebook/executionCompletionPolicy.test.js dist/extension/src/notebook/executionSummary.test.js dist/extension/src/notebook/HostKernelObservationService.test.js dist/extension/src/notebook/kernelRuntime.test.js dist/extension/src/notebook/languageFeatures.test.js dist/extension/src/notebook/outline.test.js dist/extension/src/notebook/previews.test.js dist/extension/src/notebook/searchCore.test.js dist/extension/src/notebook/variableExplorer.test.js"
  },
  "dependencies": {
    "@jupyter-mcp/protocol": "file:../packages/protocol"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.102.0",
    "typescript": "^5.9.0"
  }
}

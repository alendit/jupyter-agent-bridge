{
  "name": "@jupyter-agent-bridge/extension",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/extension/src/extension.js",
  "engines": {
    "vscode": "^1.99.0"
  },
  "activationEvents": [
    "onNotebook:jupyter-notebook",
    "onCommand:jupyterAgentBridge.startBridge",
    "onCommand:jupyterAgentBridge.stopBridge",
    "onCommand:jupyterAgentBridge.showStatus",
    "onCommand:jupyterAgentBridge.copyMcpDefinition"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jupyterAgentBridge.startBridge",
        "title": "Jupyter Agent Bridge: Start Bridge"
      },
      {
        "command": "jupyterAgentBridge.stopBridge",
        "title": "Jupyter Agent Bridge: Stop Bridge"
      },
      {
        "command": "jupyterAgentBridge.showStatus",
        "title": "Jupyter Agent Bridge: Show Status"
      },
      {
        "command": "jupyterAgentBridge.copyMcpDefinition",
        "title": "Jupyter Agent Bridge: Copy MCP Definition"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/extension/src/notebook/CellPatchService.test.js dist/extension/src/notebook/executionSummary.test.js dist/extension/src/notebook/HostKernelObservationService.test.js dist/extension/src/notebook/languageFeatures.test.js dist/extension/src/notebook/OutputNormalizationService.test.js dist/extension/src/notebook/NotebookAsyncExecutionService.test.js"
  },
  "dependencies": {
    "@jupyter-agent-bridge/notebook-domain": "file:../packages/notebook-domain",
    "@jupyter-agent-bridge/protocol": "file:../packages/protocol"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.102.0",
    "typescript": "^5.9.0"
  }
}

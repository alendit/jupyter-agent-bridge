{
  "name": "jupyter-agent-bridge",
  "displayName": "Jupyter Agent Bridge",
  "description": "Expose the live Jupyter notebook in VS Code-compatible editors as MCP tools for agents.",
  "publisher": "local",
  "version": "0.1.0",
  "private": true,
  "main": "./extension/dist/extension/src/extension.js",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onNotebook:jupyter-notebook",
    "onCommand:jupyterAgentBridge.startBridge",
    "onCommand:jupyterAgentBridge.stopBridge",
    "onCommand:jupyterAgentBridge.showStatus",
    "onCommand:jupyterAgentBridge.copyMcpDefinition"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jupyterAgentBridge.startBridge",
        "title": "Jupyter Agent Bridge: Start Bridge"
      },
      {
        "command": "jupyterAgentBridge.stopBridge",
        "title": "Jupyter Agent Bridge: Stop Bridge"
      },
      {
        "command": "jupyterAgentBridge.showStatus",
        "title": "Jupyter Agent Bridge: Show Status"
      },
      {
        "command": "jupyterAgentBridge.copyMcpDefinition",
        "title": "Jupyter Agent Bridge: Copy MCP Definition"
      }
    ]
  },
  "workspaces": [
    "packages/protocol",
    "packages/notebook-domain",
    "extension",
    "frontend-mcp"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:smoke": "node tests/integration/launch-smoke.cjs",
    "dev:host": "npm run build && code --extensionDevelopmentPath=. --new-window tests/fixtures/smoke-workspace/demo.ipynb"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2"
  }
}

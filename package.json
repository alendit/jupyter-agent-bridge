{
  "name": "jupyter-agent-bridge",
  "displayName": "Jupyter Agentic Bridge",
  "description": "Expose the live Jupyter notebook in VS Code-compatible editors as MCP tools for agents.",
  "license": "MIT",
  "publisher": "alendit",
  "version": "0.5.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/alendit/jupyter-agent-bridge.git"
  },
  "main": "./extension/dist/extension/src/extension.js",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onNotebook:jupyter-notebook",
    "onUri",
    "onCommand:jupyterAgentBridge.startBridge",
    "onCommand:jupyterAgentBridge.stopBridge",
    "onCommand:jupyterAgentBridge.showStatus",
    "onCommand:jupyterAgentBridge.createMcpConfig",
    "onCommand:jupyterAgentBridge.openCellNavigation"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jupyterAgentBridge.startBridge",
        "title": "Jupyter Agentic Bridge: Start Bridge"
      },
      {
        "command": "jupyterAgentBridge.stopBridge",
        "title": "Jupyter Agentic Bridge: Stop Bridge"
      },
      {
        "command": "jupyterAgentBridge.showStatus",
        "title": "Jupyter Agentic Bridge: Show Status"
      },
      {
        "command": "jupyterAgentBridge.createMcpConfig",
        "title": "Jupyter Agentic Bridge: Create MCP Config"
      }
    ]
  },
  "workspaces": [
    "packages/protocol",
    "packages/notebook-domain",
    "extension",
    "frontend-mcp"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test:root": "node --test tests/cut-release.test.cjs",
    "test": "npm run test:root && npm run test --workspaces --if-present",
    "test:smoke": "node tests/integration/launch-smoke.cjs",
    "dev:host": "npm run build && code --extensionDevelopmentPath=. --new-window tests/fixtures/smoke-workspace/demo.ipynb",
    "package": "npm run build && vsce package --no-dependencies --allow-missing-repository --baseContentUrl .",
    "cut-release": "node scripts/cut-release.mjs"
  },
  "devDependencies": {
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.8.0"
  }
}
